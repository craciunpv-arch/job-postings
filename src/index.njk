---
layout: layouts/base.njk
title: Vlad Crăciun — Job Opportunities
description: Personalized job opportunities, shared directly with candidates.
---
<div class="main">

  <section class="hero">
    <div class="hero-content">
      <h1 class="hero-name">{{ site.name }}</h1>
      <p class="hero-tagline">{{ site.tagline }}</p>
      <div class="hero-actions">
        <a class="btn btn-primary" href="{{ site.linkedin }}" target="_blank" rel="noopener">Connect on LinkedIn →</a>
        <a class="btn btn-secondary" href="mailto:{{ site.email }}">{{ site.email }}</a>
      </div>
    </div>
    {% if site.photo %}
    <div class="hero-photo">
      <img src="{{ site.photo }}" alt="{{ site.name }}" style="width: {{ site.heroPhotoZoom or 140 }}%; margin-left: {{ site.heroPhotoOffsetX or -20 }}%; margin-top: {{ site.heroPhotoOffsetY or -8 }}%;" />
    </div>
    {% endif %}
  </section>

  {% set openJobs = collections.jobs | selectattr("status", "equalto", "Open") %}
  {% if openJobs.length %}
  <section class="jobs-section">
    <h2 class="jobs-heading">Open Positions <span class="jobs-count">({{ openJobs | length }})</span></h2>
    <div class="job-list">
      {% for job in openJobs | reverse %}
      {% set daysSince = job.date | daysAgo %}
      <a class="job-card" href="{{ job.url }}">
        <div class="job-card-header">
          <span class="job-card-title">{{ job.data.title }}</span>
          {% if daysSince <= 7 %}<span class="job-card-new">New</span>{% endif %}
        </div>
        {% if job.data.clientTeaser %}
        <p class="job-card-teaser">{{ job.data.clientTeaser }}</p>
        {% endif %}
        <div class="job-card-footer">
          <div class="job-card-tags">
            <span class="job-card-tag">{{ job.data.city }}</span>
            <span class="job-card-tag">{{ job.data.workingType }}</span>
            {% if job.data.techStack %}
              {% for tech in job.data.techStack %}
              <span class="job-card-tag job-card-tag--tech">{{ tech }}</span>
              {% endfor %}
            {% endif %}
          </div>
          <span class="job-card-salary">{{ job.data.salary }}</span>
        </div>
      </a>
      {% endfor %}
    </div>
  </section>
  {% endif %}

</div>
