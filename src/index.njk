---
layout: layouts/base.njk
title: Hand Picked Jobs Dashboard | Edurom Recruitment
description: Hand-picked job opportunities from the Edurom recruiting team, shared directly with candidates.
---

<section class="hero">
  <div class="hero-inner">
    <p class="hero-tagline">{{ site.tagline }}</p>
  </div>
</section>

<div class="main">
  {% set openJobs = collections.jobs | selectattr("status", "equalto", "Open") %}
  {% if openJobs.length %}
  <section class="jobs-section">
    <div class="jobs-heading-row">
      <h2 class="jobs-heading">Open Positions <span class="jobs-count">({{ openJobs | length }})</span></h2>
      <div class="filter-bar" id="filterBar">
        <button class="filter-btn active" data-filter="all">All</button>
        {% for job in openJobs %}
          {% for city in job.data.city.split(", ") %}
            <button class="filter-btn" data-filter="{{ city | lower | replace(' ', '-') }}" data-label="{{ city }}">{{ city }}</button>
          {% endfor %}
          <button class="filter-btn" data-filter="{{ job.data.workingType | lower | replace(' ', '-') }}" data-label="{{ job.data.workingType }}">{{ job.data.workingType }}</button>
          {% endfor %}
      </div>
    </div>
    <div class="job-list{% if openJobs.length == 1 %} job-list--single{% endif %}" id="jobList">
      {% for job in openJobs | reverse %}
      {% set daysSince = job.date | daysAgo %}
      {% set jobBlueIndex = loop.index0 % 4 + 1 %}
      {% set filterTags = [] %}
      {% for city in job.data.city.split(", ") %}{% set filterTags = filterTags.concat([city | lower | replace(' ', '-')]) %}{% endfor %}
      {% set filterTags = filterTags.concat([job.data.workingType | lower | replace(' ', '-')]) %}
      {% if job.data.techStack %}{% for tech in job.data.techStack %}{% set filterTags = filterTags.concat([tech | lower | replace(' ', '-')]) %}{% endfor %}{% endif %}
      <a class="job-card" href="{{ job.url }}" data-tags="{{ filterTags | join(' ') }}">
        <div class="job-card-header">
          <span class="job-card-title">{{ job.data.title }}</span>
          <div class="job-card-meta-right">
            {% if daysSince <= 7 %}<span class="job-card-new">New</span>{% endif %}
          </div>
        </div>
        {% if job.data.clientTeaser %}
        <p class="job-card-teaser job-card-teaser--blue-{{ jobBlueIndex }}">{{ job.data.clientTeaser }}</p>
        {% endif %}
        <div class="job-card-footer">
          <div class="job-card-tags">
            {% for city in job.data.city.split(", ") %}
            <span class="job-card-tag job-card-tag--meta">{{ city }}</span>
            {% endfor %}
            <span class="job-card-tag job-card-tag--meta">{{ job.data.workingType }}</span>
            {% if job.data.techStack %}
              {% set blueTagClasses = ["job-card-tag--blue-1", "job-card-tag--blue-2", "job-card-tag--blue-3", "job-card-tag--blue-4"] %}
              {% for tech in job.data.techStack %}
                {% if loop.index <= 3 %}
                <span class="job-card-tag {{ blueTagClasses[loop.index0 % blueTagClasses.length] }}">{{ tech }}</span>
                {% endif %}
              {% endfor %}
            {% endif %}
          </div>
          <span class="job-card-salary job-card-salary--blue-{{ jobBlueIndex }}">{{ job.data.salary }}</span>
        </div>
        {% set recruiter = collections.team | findBySlug(job.data.recruiter) %}
        {% if recruiter %}
        {% set zoom = recruiter.data.photoZoom | default(100, true) %}
        {% set posX = recruiter.data.photoPositionX | default(50, true) %}
        {% set posY = recruiter.data.photoPositionY | default(50, true) %}
        <div class="job-card-recruiter">
          <div class="job-card-recruiter-avatar">
            <img src="{{ recruiter.data.photo }}" alt="" style="width: {{ zoom }}%; height: {{ zoom }}%; margin-left: {{ -1 * (zoom - 100) * (posX / 100) }}%; margin-top: {{ -1 * (zoom - 100) * (posY / 100) }}%;" />
          </div>
          <span class="job-card-recruiter-name">{{ recruiter.data.name }}</span>
        </div>
        {% endif %}
      </a>
      {% endfor %}
    </div>
  </section>
  {% else %}
  <div class="empty-state">
    <p class="empty-state-title">No open roles right now.</p>
    <p class="empty-state-text">Stay connected — we share new opportunities regularly.</p>
    <a class="btn btn-primary" href="{{ site.linkedin }}" target="_blank" rel="noopener">Follow our team on LinkedIn →</a>
  </div>
  {% endif %}
</div>

<script>
  (function() {
    var bar = document.getElementById('filterBar');
    if (!bar) return;

    // deduplicate filter buttons
    var seen = {};
    bar.querySelectorAll('.filter-btn[data-filter]').forEach(function(btn) {
      var key = btn.dataset.filter;
      if (key === 'all') return;
      if (seen[key]) { btn.remove(); }
      else { seen[key] = true; }
    });

    bar.addEventListener('click', function(e) {
      var btn = e.target.closest('.filter-btn');
      if (!btn) return;
      bar.querySelectorAll('.filter-btn').forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');
      var filter = btn.dataset.filter;
      document.querySelectorAll('.job-card').forEach(function(card) {
        if (filter === 'all') { card.style.display = ''; return; }
        var tags = (card.dataset.tags || '').split(' ');
        card.style.display = tags.includes(filter) ? '' : 'none';
      });
    });
  })();
</script>
