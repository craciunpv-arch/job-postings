---
layout: layouts/base.njk
---
<div class="main">
  <a class="back-link" href="/">← All positions</a>
  <article class="job-detail">
    <h1 class="job-title">{{ title }}</h1>
    <p class="job-salary">{{ salary }}</p>

    <div class="job-meta">
      <span class="job-card-tag job-card-tag--meta">{{ city }}</span>
      <span class="job-card-tag job-card-tag--meta">{{ workingType }}</span>
    </div>

    <section class="job-section">
      <h2>About the Client</h2>
      <div class="post-body">
        {{ clientDescription | markdown | safe }}
      </div>
    </section>

    <section class="job-section">
      <h2>The Role</h2>
      <div class="post-body">
        <h3>Main Responsibilities</h3>
        {{ responsibilities | markdown | safe }}

        <h3>Must-haves</h3>
        {{ mustHaves | markdown | safe }}

        <h3>Nice-to-haves</h3>
        {{ niceToHaves | markdown | safe }}
      </div>
    </section>

    <section class="job-section">
      <h2>Other Benefits</h2>
      <div class="post-body">
        {{ benefits | markdown | safe }}
      </div>
    </section>

    <section class="job-section">
      <h2>Selection Process</h2>
      <div class="post-body">
        {{ selectionProcess | markdown | safe }}
      </div>
    </section>

    <section class="job-section">
      <h2>Good to Know</h2>
      <div class="post-body">
        {{ goodToKnow | markdown | safe }}
      </div>
    </section>

    <div class="contact-cta">
      <p class="contact-cta-text">Interested in this role? Reach out and let's talk.</p>
      <a class="contact-cta-link" href="{{ site.linkedin }}" target="_blank" rel="noopener">Connect on LinkedIn →</a>
      <a class="contact-cta-link contact-cta-link--secondary" href="mailto:{{ site.email }}">Email {{ site.email }} →</a>
    </div>
  </article>
</div>
