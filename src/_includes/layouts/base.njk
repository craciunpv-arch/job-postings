<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ title }}</title>
  <meta name="description" content="{{ clientTeaser or description or site.tagline }}" />
  <meta name="theme-color" content="#fdf8f0" />
  <meta property="og:title" content="{{ title }}" />
  <meta property="og:description" content="{{ clientTeaser or description or site.tagline }}" />
  <meta property="og:image" content="{{ site.siteUrl }}{{ site.ogImage }}" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="1200" />
  <meta property="og:url" content="{{ site.siteUrl }}{{ page.url }}" />
  <meta property="og:type" content="website" />
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content="{{ title }}" />
  <meta name="twitter:description" content="{{ clientTeaser or description or site.tagline }}" />
  <meta name="format-detection" content="telephone=no,date=no,address=no,email=no,url=no" />

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>

  <div class="bg-decor bg-decor--left" aria-hidden="true"></div>
  <div class="bg-decor bg-decor--right" aria-hidden="true"></div>

  <header class="site-header">
    <div class="site-header-inner">
      <a href="https://www.edurom.ro/hand-picked-jobs/" target="_blank" rel="noopener" class="site-logo">
        <img src="/images/uploads/edurom-logo-recruitment-white.png" alt="Edurom" />
      </a>
      {% set titleWords = site.siteTitle.split(" ") %}
      <span class="site-name">{{ titleWords.slice(0, -1).join(" ") }} <span class="site-name-accent">{{ titleWords[titleWords.length - 1] }}</span></span>
    </div>
  </header>

  {{ content | safe }}

  <footer>
    <p class="footer-copyright" style="font-size: {{ site.footerFontSize | default(13, true) }}px;{% if site.footerBold %} font-weight: 700;{% endif %}{% if site.footerItalic %} font-style: italic;{% endif %}">{{ site.footerText | default("© An Edurom Recruitment Project", true) }}</p>
    {% if site.footerSubtext %}<p class="footer-subtext">{{ site.footerSubtext }}</p>{% endif %}
  </footer>

  <div class="explore-footer">
    <div class="explore-footer-inner">
      <h2 class="explore-footer-heading">Explore further:</h2>
      <div class="explore-footer-columns">
        <div class="explore-footer-col">
          <h3>IT career perspectives</h3>
          <ul>
            <li><a href="https://www.edurom.ro/do-i-really-need-to-prepare-for-an-interview/" target="_blank" rel="noopener">Prepare for your next interview</a></li>
            <li><a href="https://www.edurom.ro/in-a-world-of-recruiters-talk-with-an-edurom-consultant/" target="_blank" rel="noopener">Why talk with an EDUROM consultant</a></li>
            <li><a href="https://www.edurom.ro/job-search-experiences-through-our-it-recruitment-agency/" target="_blank" rel="noopener">Real job search experiences with us</a></li>
          </ul>
        </div>
        <div class="explore-footer-col">
          <h3>About EDUROM</h3>
          <ul>
            <li><a href="https://www.edurom.ro/about-us/" target="_blank" rel="noopener">The Edurom Group</a></li>
            <li><a href="https://www.edurom.ro/contact/" target="_blank" rel="noopener">Contact</a></li>
          </ul>
        </div>
        <div class="explore-footer-col">
          <h3>For companies</h3>
          <ul>
            <li><a href="https://www.edurom.ro/it-recruitment/" target="_blank" rel="noopener">IT Recruitment services</a></li>
            <li><a href="https://www.edurom.ro/executive-search/" target="_blank" rel="noopener">Executive Search solutions</a></li>
            <li><a href="https://www.edurom.ro/recruitment-services/case-studies/" target="_blank" rel="noopener">Recruitment case studies</a></li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
