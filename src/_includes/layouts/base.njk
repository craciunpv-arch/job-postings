<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ title }}</title>
  <meta name="description" content="{{ clientTeaser or description or site.tagline }}" />
  <meta name="theme-color" content="#fdf8f0" />
  <meta property="og:title" content="{{ title }}" />
  <meta property="og:description" content="{{ clientTeaser or description or site.tagline }}" />
  <meta property="og:image" content="{{ site.siteUrl }}{{ site.ogImage }}" />
  <meta property="og:url" content="{{ site.siteUrl }}{{ page.url }}" />
  <meta property="og:type" content="website" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="{{ title }}" />
  <meta name="twitter:description" content="{{ clientTeaser or description or site.tagline }}" />
  <meta name="format-detection" content="telephone=no,date=no,address=no,email=no,url=no" />

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>

  <header class="site-header">
    <div class="site-header-inner">
      <a href="https://www.edurom.ro" target="_blank" rel="noopener" class="site-logo">
        <img src="/images/uploads/edurom-logo-recruitment.png" alt="Edurom" />
      </a>
      <span class="site-name">{{ site.siteTitle }}</span>
    </div>
  </header>

  {{ content | safe }}

  <footer>
    <p class="footer-copyright" style="font-size: {{ site.footerFontSize | default(13, true) }}px;{% if site.footerBold %} font-weight: 700;{% endif %}{% if site.footerItalic %} font-style: italic;{% endif %}">{{ site.footerText | default("© An Edurom Recruitment Project", true) }}</p>
    {% if site.footerSubtext %}<p class="footer-subtext">{{ site.footerSubtext }}</p>{% endif %}
  </footer>
</body>
</html>
